# polymarket-glm environment configuration
# Copy this file to .env and fill in your values

# ── Execution Mode ──────────────────────────────────
# PGLM_MODE=paper     # paper trading (simulated fills, no real orders)
# PGLM_MODE=live      # live trading (REAL ORDERS — requires API keys)

# ── Polymarket API Keys (required for LIVE mode) ────
# Get these from https://polymarket.com → Settings → API Keys
# PGLM_API_KEY=your_api_key_here
# PGLM_API_SECRET=your_api_secret_here
# PGLM_PRIVATE_KEY=0x_your_ethereum_private_key_here

# ── CLOB Configuration ──────────────────────────────
PGLM_CLOB_URL=https://clob.polymarket.com
PGLM_GAMMA_URL=https://gamma-api.polymarket.com

# ── Risk Parameters ─────────────────────────────────
PGLM_MAX_TOTAL_EXPOSURE_USD=1000
PGLM_MAX_PER_TRADE_USD=100
PGLM_DAILY_LOSS_LIMIT_USD=50
PGLM_DRAWDOWN_CIRCUIT_BREAKER_PCT=0.20
PGLM_DRAWDOWN_ARM_PERIOD_SEC=60
PGLM_DRAWDOWN_MIN_OBSERVATIONS=10

# ── Strategy Parameters ─────────────────────────────
PGLM_MIN_EDGE_BPS=200
PGLM_KELLY_FRACTION=0.25

# ── LLM Estimator (optional — Sprint 7) ─────────────
# PGLM_LLM_PROVIDER=openai
# PGLM_LLM_MODEL=gpt-4o-mini
# PGLM_LLM_API_KEY=sk-your-openai-key-here

# ── Telegram Alerts (optional) ──────────────────────
# PGLM_TELEGRAM_BOT_TOKEN=123456:ABC-DEF
# PGLM_TELEGRAM_CHAT_ID=your_chat_id_here

# ── Storage ─────────────────────────────────────────
PGLM_DB_PATH=polymarket_glm.db

# ── Logging ─────────────────────────────────────────
PGLM_LOG_LEVEL=INFO
